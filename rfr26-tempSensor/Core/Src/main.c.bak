/* USER CODE BEGIN Header */
/**
 * Temperature Monitoring Board 2026 MK1
 * FLOAT-FREE VERSION (Fixed-point 0.1°C)
 *
 * 3x ADG731 32-channel multiplexer driver
 *
 * Hardware topology:
 *   U201 D (pin 43) ─┐
 *   U202 D (pin 43) ─┼─ MUX_OUTPUT → TLV9102 filter → PA2 (ADC1_IN2)
 *   U203 D (pin 43) ─┘
 *
 *   SPI1 SCK  = PA5  (shared SCLK to all 3 muxes)
 *   SPI1 MOSI = PA7  (shared DIN  to all 3 muxes)
 *   SYNC1     = PB0  → U201
 *   SYNC2     = PB1  → U202
 *   SYNC3     = PB2  → U203
 *
 * IMPORTANT - wired-OR output bus rule:
 *   Only ONE mux may have a switch closed at any time.
 *   All inactive muxes must have EN=1 (all switches OFF).
 */
/* USER CODE END Header */

#include "main.h"
#include <stdint.h>
#include <string.h>
#include <stdio.h>

/* Semihosting: routes printf() over SWD to the IDE console.
 * Requires the semihosting runtime to be enabled in your project:
 *   - STM32CubeIDE: Run Configurations → Debugger → Enable semihosting
 *   - Or add  -specs=rdimon.specs -lrdimon  to your linker flags
 *     and remove the syscalls.c stub if present.                       */
extern void initialise_monitor_handles(void);

/* ------------------------------------------------------------------ */
/*                          DEFINES                                   */
/* ------------------------------------------------------------------ */

/* SYNC pins — all on GPIOB, matching schematic SYNC1/2/3 */
#define MUX1_SYNC_PIN   GPIO_PIN_0   /* PB0 → U201 */
#define MUX2_SYNC_PIN   GPIO_PIN_1   /* PB1 → U202 */
#define MUX3_SYNC_PIN   GPIO_PIN_2   /* PB2 → U203 */
#define MUX_SYNC_PORT   GPIOB

/* ADG731 command byte:
 *  DB7  DB6  DB5  DB4  DB3  DB2  DB1  DB0
 *  EN   CS   X    A4   A3   A2   A1   A0
 *
 *  EN=0, CS=0, A[4:0]=channel-1  → close switch N
 *  EN=1                          → all switches OFF  */
#define ADG731_EN_BIT    (1u << 7)
#define ADG731_ADDR_MASK (0x1Fu)

/* Mux topology */
#define MUX_NUM_MUX      3u
#define MUX_NUM_CHANNELS 32u
#define MUX_TOTAL_CH     (MUX_NUM_MUX * MUX_NUM_CHANNELS)   /* 96 */

/* ADC — 12-bit, ISO 3V3 reference */
#define ADC_VREF_MV      3300u
#define ADC_FULLSCALE    4095u

/* ------------------------------------------------------------------ */
/*                          HAL HANDLES                               */
/* ------------------------------------------------------------------ */

ADC_HandleTypeDef hadc1;
CAN_HandleTypeDef hcan;
SPI_HandleTypeDef hspi1;

/* ------------------------------------------------------------------ */
/*                       FUNCTION PROTOTYPES                          */
/* ------------------------------------------------------------------ */

void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_ADC1_Init(void);
static void MX_CAN_Init(void);
static void MX_SPI1_Init(void);

/* Mux driver */
void     MUX_Init(void);
uint32_t MUX_ReadChannel(uint8_t mux_idx, uint8_t channel);
void     MUX_ScanAll(uint32_t *results_mV);

/* ------------------------------------------------------------------ */
/*                       MUX DESCRIPTOR TABLE                         */
/* ------------------------------------------------------------------ */

typedef struct {
    GPIO_TypeDef *sync_port;
    uint16_t      sync_pin;
} MuxDevice_t;

static const MuxDevice_t s_mux[MUX_NUM_MUX] = {
    { MUX_SYNC_PORT, MUX1_SYNC_PIN },   /* 0 → U201 */
    { MUX_SYNC_PORT, MUX2_SYNC_PIN },   /* 1 → U202 */
    { MUX_SYNC_PORT, MUX3_SYNC_PIN },   /* 2 → U203 */
};

/* ------------------------------------------------------------------ */
/*                       SENSOR LABEL TABLE                           */
/* ------------------------------------------------------------------ */
/* Friendly names from the schematic. Index = mux*32 + (channel-1).
 * Adjust if your physical wiring differs.                            */
static const char * const sensor_labels[MUX_TOTAL_CH] = {
    /* U201 (mux 0) channels 1–32 */
    "ch1","ch2","ch3","ch4","ch5","ch6",
    "ch7","ch8","ch9","ch10","ch11","ch12",
    "ch13","ch14","ch15","ch16","ch17","ch18",
    "ch19","ch20","ch21","ch22","ch23","ch24",
    "ch25","ch26","ch27","ch28","ch29","ch30",
    "ch31","ch32",
    /* U202 (mux 1) channels 1–32 */
	"ch1","ch2","ch3","ch4","ch5","ch6",
	"ch7","ch8","ch9","ch10","ch11","ch12",
	"ch13","ch14","ch15","ch16","ch17","ch18",
	"ch19","ch20","ch21","ch22","ch23","ch24",
	"ch25","ch26","ch27","ch28","ch29","ch30",
	"ch31","ch32",
    /* U203 (mux 2) channels 1–32 */
	"ch1","ch2","ch3","ch4","ch5","ch6",
	"ch7","ch8","ch9","ch10","ch11","ch12",
	"ch13","ch14","ch15","ch16","ch17","ch18",
	"ch19","ch20","ch21","ch22","ch23","ch24",
	"ch25","ch26","NOT IN USE","NOT IN USE","NOT IN USE","NOT IN USE",
	"NOT IN USE","NOT IN USE",
};

/* ------------------------------------------------------------------ */
/*                             MAIN                                   */
/* ------------------------------------------------------------------ */

int main(void) {
    initialise_monitor_handles();   

    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_ADC1_Init();
    MX_CAN_Init();
    MX_SPI1_Init();

    HAL_ADCEx_Calibration_Start(&hadc1);
    HAL_CAN_Start(&hcan);

    MUX_Init();  

    printf("Temperature Monitoring Board 2026\r\n");

    uint32_t readings_mV[MUX_TOTAL_CH];

    while (1) {
        MUX_ScanAll(readings_mV);

        for (uint8_t i = 0u; i < MUX_TOTAL_CH; i++) {
            if (readings_mV[i] == 0xFFFFFFFFu) {
                printf("%s: ERR\r\n", sensor_labels[i]);
            } else {
                printf("%s: %4lu mV\r\n", sensor_labels[i], readings_mV[i]);
            }
        }

        printf("---\r\n");
        HAL_Delay(500);
    }
}

/* ------------------------------------------------------------------ */
/*                          MUX DRIVER                                */
/* ------------------------------------------------------------------ */

/* Send EN=1 to one mux → all its switches OFF (safe/idle state) */
static void MUX_DisableDevice(uint8_t mux_idx)
{
    uint8_t cmd = ADG731_EN_BIT;

    HAL_GPIO_WritePin(s_mux[mux_idx].sync_port, s_mux[mux_idx].sync_pin,
                      GPIO_PIN_RESET);
    HAL_SPI_Transmit(&hspi1, &cmd, 1u, 10u);
    HAL_GPIO_WritePin(s_mux[mux_idx].sync_port, s_mux[mux_idx].sync_pin,
                      GPIO_PIN_SET);
}

/* Select channel [1..32] on one mux.
 * Caller must have already disabled all other muxes. */
static HAL_StatusTypeDef MUX_SelectChannel(uint8_t mux_idx, uint8_t channel)
{
    if (channel < 1u || channel > 32u || mux_idx >= MUX_NUM_MUX)
        return HAL_ERROR;

    /* EN=0, CS=0, address = channel-1 */
    uint8_t cmd = (uint8_t)((channel - 1u) & ADG731_ADDR_MASK);

    HAL_GPIO_WritePin(s_mux[mux_idx].sync_port, s_mux[mux_idx].sync_pin,
                      GPIO_PIN_RESET);
    HAL_StatusTypeDef status = HAL_SPI_Transmit(&hspi1, &cmd, 1u, 10u);
    HAL_GPIO_WritePin(s_mux[mux_idx].sync_port, s_mux[mux_idx].sync_pin,
                      GPIO_PIN_SET);

    return status;
}

/* Trigger one ADC conversion, return millivolts. 0xFFFFFFFF = error. */
static uint32_t ADC_ReadMV(void)
{
    HAL_ADC_Start(&hadc1);

    if (HAL_ADC_PollForConversion(&hadc1, 10u) != HAL_OK) {
        HAL_ADC_Stop(&hadc1);
        return 0xFFFFFFFFu;
    }

    uint32_t raw = HAL_ADC_GetValue(&hadc1);
    HAL_ADC_Stop(&hadc1);

    return (raw * ADC_VREF_MV) / ADC_FULLSCALE;
}

/* Call once after peripheral init. Forces all three muxes to EN=1. */
void MUX_Init(void)
{
    /* Deassert all SYNCs first so no spurious frames are sent */
    for (uint8_t i = 0u; i < MUX_NUM_MUX; i++)
        HAL_GPIO_WritePin(s_mux[i].sync_port, s_mux[i].sync_pin, GPIO_PIN_SET);

    /* Now send EN=1 to each mux explicitly */
    for (uint8_t i = 0u; i < MUX_NUM_MUX; i++)
        MUX_DisableDevice(i);
}

/* Read one channel from one mux. Disables the other two first. */
uint32_t MUX_ReadChannel(uint8_t mux_idx, uint8_t channel)
{
    if (mux_idx >= MUX_NUM_MUX || channel < 1u || channel > 32u)
        return 0xFFFFFFFFu;

    /* Disable all OTHER muxes (wired-OR bus safety) */
    for (uint8_t i = 0u; i < MUX_NUM_MUX; i++) {
        if (i != mux_idx) MUX_DisableDevice(i);
    }

    if (MUX_SelectChannel(mux_idx, channel) != HAL_OK) {
        MUX_DisableDevice(mux_idx);
        return 0xFFFFFFFFu;
    }

    uint32_t result = ADC_ReadMV();
    MUX_DisableDevice(mux_idx);
    return result;
}

/* Scan all 3 muxes × 32 channels = 96 readings.
 * results_mV[mux*32 + (ch-1)] holds each reading in millivolts. */
void MUX_ScanAll(uint32_t *results_mV)
{
    for (uint8_t mux = 0u; mux < MUX_NUM_MUX; mux++) {
        /* Disable all other muxes once per device, not per channel */
        for (uint8_t i = 0u; i < MUX_NUM_MUX; i++) {
            if (i != mux) MUX_DisableDevice(i);
        }

        for (uint8_t ch = 1u; ch <= MUX_NUM_CHANNELS; ch++) {
            uint32_t idx = (uint32_t)mux * MUX_NUM_CHANNELS + (ch - 1u);

            if (MUX_SelectChannel(mux, ch) != HAL_OK) {
                results_mV[idx] = 0xFFFFFFFFu;
                continue;
            }

            results_mV[idx] = ADC_ReadMV();
        }

        MUX_DisableDevice(mux);   /* safe state between devices */
    }
}

/* ------------------------------------------------------------------ */
/*                      PERIPHERAL INIT                               */
/* ------------------------------------------------------------------ */

/* HSI @ 8 MHz, no PLL. ADC clock = APB2 / 2 = 4 MHz. */
void SystemClock_Config(void) {
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};
    RCC_PeriphCLKInitTypeDef PeriphClkInit = {0};

    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI;
    RCC_OscInitStruct.HSIState = RCC_HSI_ON;
    RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
    RCC_OscInitStruct.PLL.PLLState = RCC_PLL_NONE;
    if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
        Error_Handler();

    RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK | RCC_CLOCKTYPE_SYSCLK |
                                  RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_HSI;
    RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
    if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_0) != HAL_OK)
        Error_Handler();

    PeriphClkInit.PeriphClockSelection = RCC_PERIPHCLK_ADC;
    PeriphClkInit.AdcClockSelection = RCC_ADCPCLK2_DIV2;   /* 4 MHz ADC clock */
    if (HAL_RCCEx_PeriphCLKConfig(&PeriphClkInit) != HAL_OK)
        Error_Handler();
}

/* Channel 2 (PA2 = MUX_FILT_OUT). Signal pre-filtered by U302 op-amp. */
static void MX_ADC1_Init(void) {
    ADC_ChannelConfTypeDef sConfig = {0};

    hadc1.Instance = ADC1;
    hadc1.Init.ScanConvMode = ADC_SCAN_DISABLE;
    hadc1.Init.ContinuousConvMode = DISABLE;
    hadc1.Init.DiscontinuousConvMode = DISABLE;
    hadc1.Init.ExternalTrigConv = ADC_SOFTWARE_START;
    hadc1.Init.DataAlign = ADC_DATAALIGN_RIGHT;
    hadc1.Init.NbrOfConversion = 1;
    if (HAL_ADC_Init(&hadc1) != HAL_OK)
        Error_Handler();

    sConfig.Channel = ADC_CHANNEL_2;
    sConfig.Rank = ADC_REGULAR_RANK_1;
    sConfig.SamplingTime = ADC_SAMPLETIME_1CYCLE_5;   /* U302 pre-filters signal */
    if (HAL_ADC_ConfigChannel(&hadc1, &sConfig) != HAL_OK)
        Error_Handler();
}

static void MX_CAN_Init(void) {
    hcan.Instance = CAN1;
    hcan.Init.Prescaler = 16;
    hcan.Init.Mode = CAN_MODE_NORMAL;
    hcan.Init.SyncJumpWidth = CAN_SJW_1TQ;
    hcan.Init.TimeSeg1 = CAN_BS1_1TQ;
    hcan.Init.TimeSeg2 = CAN_BS2_1TQ;
    hcan.Init.TimeTriggeredMode = DISABLE;
    hcan.Init.AutoBusOff = DISABLE;
    hcan.Init.AutoWakeUp = DISABLE;
    hcan.Init.AutoRetransmission = DISABLE;
    hcan.Init.ReceiveFifoLocked = DISABLE;
    hcan.Init.TransmitFifoPriority = DISABLE;
    if (HAL_CAN_Init(&hcan) != HAL_OK)
        Error_Handler();
}

/* PA5 = SCLK, PA7 = MOSI. 1-line transmit-only (ADG731 has no MISO).
 * BAUDRATEPRESCALER_2 → 4 MHz SPI @ 8 MHz SYSCLK (within ADG731's 30 MHz max) */
static void MX_SPI1_Init(void) {
    hspi1.Instance = SPI1;
    hspi1.Init.Mode = SPI_MODE_MASTER;
    hspi1.Init.Direction = SPI_DIRECTION_1LINE;
    hspi1.Init.DataSize = SPI_DATASIZE_8BIT;
    hspi1.Init.CLKPolarity = SPI_POLARITY_LOW;
    hspi1.Init.CLKPhase = SPI_PHASE_1EDGE;
    hspi1.Init.NSS = SPI_NSS_SOFT;
    hspi1.Init.BaudRatePrescaler = SPI_BAUDRATEPRESCALER_2;
    hspi1.Init.FirstBit = SPI_FIRSTBIT_MSB;
    hspi1.Init.TIMode = SPI_TIMODE_DISABLE;
    hspi1.Init.CRCCalculation = SPI_CRCCALCULATION_DISABLE;
    hspi1.Init.CRCPolynomial = 10;
    if (HAL_SPI_Init(&hspi1) != HAL_OK)
        Error_Handler();
}

/* PB0/PB1/PB2 push-pull outputs, initially HIGH (all muxes disabled).
 * Write HIGH before configuring mode to prevent spurious low glitch. */
static void MX_GPIO_Init(void) {
    GPIO_InitTypeDef GPIO_InitStruct = {0};

    __HAL_RCC_GPIOD_CLK_ENABLE();
    __HAL_RCC_GPIOA_CLK_ENABLE();
    __HAL_RCC_GPIOB_CLK_ENABLE();

    HAL_GPIO_WritePin(MUX_SYNC_PORT,
                      MUX1_SYNC_PIN | MUX2_SYNC_PIN | MUX3_SYNC_PIN,
                      GPIO_PIN_SET);

    GPIO_InitStruct.Pin = MUX1_SYNC_PIN | MUX2_SYNC_PIN | MUX3_SYNC_PIN;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    HAL_GPIO_Init(MUX_SYNC_PORT, &GPIO_InitStruct);
}

/* ------------------------------------------------------------------ */
/*                         ERROR HANDLER                              */
/* ------------------------------------------------------------------ */

void Error_Handler(void) {
    __disable_irq();
    while (1) {}
}

